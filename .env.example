# ──────────────────────────────────────────────────
# EasyLayer website — local development environment
# Copy to .env and fill in the values.
# ──────────────────────────────────────────────────

# Dev API server port
PORT=3001
NODE_ENV=development

# CORS allowed origins for local dev
CORS_ORIGINS=http://localhost:3000

# ── Telegram Bot (Enterprise leads) ───────────────
# 1. Create a bot via @BotFather in Telegram → get token
# 2. Start a conversation with your bot (or add it to a group)
# 3. Send a message, then call:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    to find your CHAT_ID (it's in result[0].message.chat.id)
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789

# ── hCaptcha (optional, recommended for production) ──
# Register at https://www.hcaptcha.com → add site → get both keys.
#
# SITEKEY — public, goes into docusaurus.config.ts customFields.
# In production set HCAPTCHA_SITEKEY in Vercel env vars so it gets
# baked into the build. Locally the test key is used automatically.
HCAPTCHA_SITEKEY=your-sitekey-from-hcaptcha-com

# SECRET — private, used on the backend (Vercel Function) to verify the token.
HCAPTCHA_SECRET=your-secret-from-hcaptcha-com

# NEVER set to true in production — bypasses captcha verification entirely.
HCAPTCHA_ALLOW_DEV_BYPASS=false
